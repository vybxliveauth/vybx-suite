{
  "name": "vybx-suite",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:promoter": "turbo dev --filter=@vybx/promoter",
    "typecheck": "turbo typecheck",
    "probe:prod": "bash scripts/probe-production.sh",
    "hardening:preprod": "bash scripts/preprod-hardening.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.5.4"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "tailwindcss": "^4.2.2"
  }
}
