{
  "name": "vybx-suite",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:account": "turbo dev --filter=@vybx/account",
    "dev:promoter": "turbo dev --filter=@vybx/promoter",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "turbo typecheck",
    "probe:prod": "bash scripts/probe-production.sh",
    "probe:mobile-auth": "bash scripts/probe-mobile-auth.sh",
    "probe:mobile-events": "bash scripts/probe-mobile-events.sh",
    "hardening:mobile-release": "bash scripts/hardening-mobile-release.sh",
    "hardening:preprod": "bash scripts/preprod-hardening.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.5.4",
    "typescript": "5.9.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "lodash": "^4.18.1"
    }
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored --config apps/web/eslint.config.mjs"
    ],
    "apps/promoter/**/*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored --config apps/promoter/eslint.config.mjs"
    ],
    "apps/admin/**/*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored --config apps/admin/eslint.config.mjs"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "tailwindcss": "^4.2.2"
  }
}
