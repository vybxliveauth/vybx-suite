# URL del backend — incluye /api/v1
# Pruebas rápidas en celular real (sin backend local):
EXPO_PUBLIC_API_URL=https://api.vybxlive.com/api/v1
EXPO_PUBLIC_ACCOUNT_APP_URL=https://account.vybxlive.com
# Nota: en produccion, /auth/register requiere Turnstile; si falla registro en app,
# crea la cuenta en web y luego inicia sesion en mobile.
# No se admite bypass de Turnstile desde el cliente mobile en produccion.

# Local por red (ejemplo, cambia por tu IP LAN):
# EXPO_PUBLIC_API_URL=http://192.168.8.132:3004/api/v1
# EXPO_PUBLIC_ACCOUNT_APP_URL=http://192.168.8.132:3005
