{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "typeRoots": ["./node_modules/@types", "../../node_modules/@types"],
    "paths": {
      "@/*": ["./src/*"],
      "@vybx/auth-core": ["../../packages/auth-core/src/index.ts"],
      "@vybx/auth-core/*": ["../../packages/auth-core/src/*"],
      "@vybx/auth-mobile": ["../../packages/auth-mobile/src/index.ts"],
      "@vybx/auth-mobile/*": ["../../packages/auth-mobile/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
